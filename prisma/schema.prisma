// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Video {
  id          String   @id @default(cuid())
  youtubeUrl  String
  youtubeId   String
  title       String?
  thumbnail   String?
  duration    Int?     // in seconds
  status      String   @default("pending") // pending, processing, completed, failed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  segments    Segment[]
}

model Segment {
  id          String   @id @default(cuid())
  videoId     String
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  
  startTime   Float    // in seconds
  endTime     Float    // in seconds
  score       Float    // relevance score 0-1
  selected    Boolean  @default(true)
  
  // Metadata generated by AI
  title       String?
  description String?
  thumbnailUrl String?
  
  // Transcript from YouTube
  transcript  String?
  transcriptAnalysis String? // AI analysis of transcript content for quality grading
  
  // Vertical crop position (0-1, where 0.5 is center)
  cropX       Float    @default(0.5)
  
  // Output
  outputPath  String?
  processed   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
